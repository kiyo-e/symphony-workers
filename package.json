{
  "name": "symphony-workers",
  "version": "0.2.3",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "symphony-workers": "./bin/symphony-workers.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "!dist/entry.*",
    "templates/cloudflare-worker",
    "NOTICE.md",
    "README.md",
    "README.ja.md"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "prepack": "bun run build",
    "workflow:init": "cp WORKFLOW.md.example WORKFLOW.md",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@cloudflare/sandbox": "0.12.1",
    "hono": "4.12.26",
    "liquidjs": "10.27.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260619.1",
    "@types/node": "25.9.3",
    "typescript": "6.0.3",
    "wrangler": "4.102.0"
  },
  "engines": {
    "node": ">=20"
  }
}
